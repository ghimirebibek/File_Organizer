# Copy this file to .env and adjust as needed, or use the Settings... item
# in the tray menu instead — it writes to .env for you.

# Folder to watch for new files. If unset, the OS Downloads folder is detected automatically.
FOLDER_TO_TRACK=C:\Users\Bibek\Downloads

# Where the sorted subfolders (Downloaded Images, Downloaded Audio, ...) get created.
# If unset, defaults to FOLDER_TO_TRACK (subfolders nested inside the watched folder).
DESTINATION_ROOT=C:\Users\Bibek\Downloads
